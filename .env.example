# Antigravity Defense Suite - Environment Variables
# Copy this file to .env and fill in your secrets
# NEVER commit .env to version control!

# Canary Token - Hidden marker to detect prompt leakage
# Choose a unique, unguessable string
CANARY_TOKEN=your_secret_canary_token_here

# Additional canary tokens (optional)
CANARY_TOKEN_2=
CANARY_TOKEN_3=

# Custom banned words (comma-separated)
CUSTOM_BANNED_WORDS=

# Alert webhook URL (optional - for notifications)
ALERT_WEBHOOK_URL=

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
